# ============================================
# AUREXIS AI - CLEAN .gitignore
# ============================================
# AI Tool folders
.gemini/
.kiro/
.claude/
_bmad/

# Reports
*-report.json

# Excel / temp data (optional)
*.xlsx

# ── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.dylib
*.dll

# Virtual Environments
venv/
env/
.venv/

# Python Packaging
build/
dist/
*.egg-info/

# ── Environment & Secrets ───────────────────
.env
.env.*
secrets.json
credentials.json
*.pem
*.key

# ── Database ────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm
*.sqlite3-wal
*.sqlite3-shm

# ── Logs ────────────────────────────────────
*.log
logs/

# ── Node.js / Frontend ──────────────────────
node_modules/
dist/
build/
.next/
out/

# ── Testing ─────────────────────────────────
.pytest_cache/
.coverage*
htmlcov/

# ── IDE & Editors ───────────────────────────
.vscode/
.idea/
*.swp
*~

# ── OS Files ────────────────────────────────
.DS_Store
Thumbs.db

# ── Temporary Files ─────────────────────────
*.tmp
*.bak

# ── Cache ───────────────────────────────────
.cache/
.parcel-cache/
.vite/

# ── AI / ML Models (if large) ───────────────
*.pkl
*.joblib
models/
checkpoints/

# ── Large Files (optional) ──────────────────
*.zip
*.tar.gz
*.rar

# ── KEEP IMPORTANT FILES ────────────────────
!README.md
!requirements.txt
!package.json
!package-lock.json
!yarn.lock

# Keep sample data only
data/*
!data/sample.*

# ── App Generated Folders ───────────────────
exports/
backups/