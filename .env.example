# AUREXIS AI - Environment Configuration Example
# Copy this file to .env and update values for your environment

# ==================== Application ====================
ENVIRONMENT=development  # development, staging, production
DEBUG=True
APP_NAME=AUREXIS AI
APP_VERSION=2.0.0

# ==================== Server ====================
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=True

# ==================== Security ====================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_MIN_LENGTH=8

# ==================== Frontend ====================
VITE_API_BASE_URL=http://localhost:8000

# ==================== Database ====================
DATABASE_URL=sqlite:///./aurexis.db
DATABASE_ECHO=False

# ==================== Redis Cache ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL=3600
CACHE_ENABLED=True

# ==================== Ollama AI ====================
# Use http://host.docker.internal:11434 for Docker on Windows/Mac
# Use http://localhost:11434 for local development
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-v2:7b
OLLAMA_TIMEOUT=120

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_FILE=logs/aurexis.log

# ==================== CORS ====================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://localhost:80

# ==================== File Storage ====================
USER_DATA_DIR=user_data
