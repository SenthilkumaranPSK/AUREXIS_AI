# AUREXIS AI Backend Configuration
# Copy this file to .env and update with your values

# ── Application ────────────────────────────────────────────────────────
APP_NAME=AUREXIS AI
APP_VERSION=2.0.0
DEBUG=False
ENVIRONMENT=development  # development, staging, production

# ── Server ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=True

# ── Security ───────────────────────────────────────────────────────────
# CRITICAL: Generate a secure key with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_MIN_LENGTH=8

# ── CORS ───────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./aurexis.db
DATABASE_ECHO=False

# ── Redis Cache ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL=3600
CACHE_ENABLED=True

# ── Ollama AI ──────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3
OLLAMA_CONTEXT_WINDOW=10

# ── Rate Limiting ──────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_CHAT_PER_MINUTE=10
RATE_LIMIT_ML_PER_HOUR=20

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/aurexis.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ── ML & Analytics ─────────────────────────────────────────────────────
ML_FORECAST_STEPS=6
ML_CACHE_HOURS=24
ANALYTICS_CACHE_MINUTES=30
BACKGROUND_TASKS_ENABLED=True

# ── Monitoring ─────────────────────────────────────────────────────────
METRICS_ENABLED=True
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Email (Future) ─────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@aurexis.ai
