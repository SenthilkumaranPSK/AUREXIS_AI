# ============================================
# AUREXIS AI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ── Application ─────────────────────────────
APP_NAME=AUREXIS AI
APP_VERSION=2.0.0
ENVIRONMENT=development  # development, staging, production
DEBUG=true

# ── Security ────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for sensitive data (32 bytes base64)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=your-encryption-key-here

# ── Database ────────────────────────────────
# For production use PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./aurexis.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aurexis

# ── Redis Cache ─────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false
CACHE_TTL=300  # seconds

# ── AI / Ollama ─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_ENABLED=false

# ── Email Service ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@aurexis.ai
EMAIL_ENABLED=false

# ── SMS Service ─────────────────────────────
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
SMS_ENABLED=false

# ── Monitoring ──────────────────────────────
SENTRY_DSN=your-sentry-dsn
SENTRY_ENABLED=false

PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ── Rate Limiting ───────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ── CORS ────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# ── File Storage ────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=.pdf,.csv,.xlsx,.json

# ── Backup ──────────────────────────────────
BACKUP_ENABLED=true
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
AUTO_BACKUP_INTERVAL_HOURS=24

# ── Logging ─────────────────────────────────
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=./logs/aurexis.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ── Feature Flags ───────────────────────────
FEATURE_2FA_ENABLED=true
FEATURE_BIOMETRIC_ENABLED=false
FEATURE_PORTFOLIO_OPTIMIZER=true
FEATURE_BUDGET_PLANNER=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_PDF_REPORTS=true
FEATURE_GLOBAL_SEARCH=true
